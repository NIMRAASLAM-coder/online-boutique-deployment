# .gitignore
# Files to exclude from Git version control
# For Google microservices-demo + deployment automation

# ========== TERRAFORM ==========
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
terraform/.terraform
terraform/.terraform.lock.hcl
terraform/terraform.tfstate*

# ========== ANSIBLE ==========
*.retry
ansible/*.retry
ansible/roles/**/*.retry

# ========== PYTHON ==========
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
env/
venv/
ENV/
env.bak/
venv.bak/
.pytest_cache/
.coverage
htmlcov/

# ========== NODE/NPM ==========
node_modules/
npm-debug.log
npm-error.log
package-lock.json
yarn.lock
.npm
.eslintcache

# ========== GO ==========
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.sum
vendor/
*.go~

# ========== JAVA ==========
*.class
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
.gradle/
.gradle
build/
out/

# ========== IDE / EDITOR ==========
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
.Xcode.app
.Xcode
*.xcworkspace
*.sublime-project
*.sublime-workspace
.netbeans
.project
.pydevproject
.settings/
*.code-workspace
.classpath

# ========== SSH / AWS / CREDENTIALS ==========
*.pem
*.pub
*.key
*.ppk
.ssh/
.aws/
aws_credentials
credentials
~/.aws
.env
.env.local
.env.*.local
.env.production.local

# ========== DOCKER ==========
docker-compose.override.yml
.dockerignore
.docker/
docker-machine/
*.container.log

# ========== KUBERNETES ==========
kubeconfig
.kube/
*.kubeconfig
kubectl.config

# ========== BUILD/DIST ARTIFACTS ==========
dist/
build/
*.o
*.a
*.so
*.dylib
target/
.gradle
.classpath
.project
.settings/
bin/

# ========== OS FILES ==========
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ========== LOGS ==========
*.log
*.log.*
logs/
log/
*.slog

# ========== MISC FILES ==========
*.tmp
*.temp
*.bak
*.backup
*.swp
*~
.classpath
.project
.settings
.externalToolBuilders/
.loadpath
.factorypath
*.iml
.gradle
local.properties
proguard-project.txt

# ========== CI/CD ARTIFACTS ==========
.github/workflows/*.log
.github/workflows/artifacts/
github-actions-cache/

# ========== DEVELOPMENT ==========
.venv
.env.development
.env.test
debug.log
test-results/
coverage/
.nyc_output/
.nycrc

# ========== GOOGLE MICROSERVICES-DEMO SPECIFIC ==========
src/*/vendor/
src/*/.gradle
src/*/.gradle/
src/*/go.sum
src/*/node_modules/
src/*/__pycache__/
src/*/.pytest_cache/
src/*/.coverage
src/*/dist/
src/*/build/
src/*/out/
src/*/.DS_Store
src/*/.vscode/
src/*/.idea/
src/*/target/

# ========== TERRAFORM SPECIFIC ==========
terraform/terraform.tfvars
!terraform/terraform.tfvars.example
terraform/.terraformrc
terraform/override.tf
terraform/override.tf.json

# ========== SKAFFOLD/K8S DEV ==========
skaffold.yaml.local
skaffold-config/
k8s-manifest-gen/
kustomization.yaml.local

# ========== SENSITIVE DATA (NEVER COMMIT!) ==========
secrets.yml
secrets.yaml
.secrets
.secrets/
credentials.json
serviceAccount.json
private_key
config/secrets
**/*secret*
**/*password*
**/*token*

# ========== TEMPORARY FILES ==========
*.tmp
*.temp
*.swp
*~
.#*
*#
*.bak
*.orig
.merge_file_*
*.rej
